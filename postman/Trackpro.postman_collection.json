    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up Farmer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Farmer\",\n  \"email\": \"farmer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": "const j = pm.response.json();\nif (j.accessToken) {\n  pm.environment.set('accessToken', j.accessToken);\n  pm.collectionVariables.set('accessToken', j.accessToken);\n}\nif (j.user && j.user.id) {\n  if (j.user.role === 'farmer') {\n    pm.environment.set('farmerId', j.user.id);\n    pm.collectionVariables.set('farmerId', j.user.id);\n  }\n  if (j.user.role === 'doctor') {\n    pm.environment.set('doctorId', j.user.id);\n    pm.collectionVariables.set('doctorId', j.user.id);\n  }\n}"
              }
            }
          ]
