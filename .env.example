# Server
PORT=3000
# Set to false to disable Swagger UI at /api/docs (e.g. production)
SWAGGER_ENABLED=true
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Logo shown at the top of transactional emails (Mailgen)
EMAIL_LOGO_URL=https://res.cloudinary.com/dbu0aqiao/image/upload/trackpro/email-logo.png

# CORS — universal allows any origin (default). localhost:3000 is always allowed in development.
CORS_UNIVERSAL=true
# Explicit whitelist (used when CORS_UNIVERSAL=false):
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# CSRF — only for browser clients using httpOnly JWT cookies (not Bearer / mobile)
CSRF_ENABLED=false
# CSRF_COOKIE_NAME=csrf_token

# Client platforms: mobile apps should send Authorization: Bearer <token> (no CSRF).
# Web SPAs: Bearer recommended; or cookies + CSRF when CSRF_ENABLED=true

# Rate limiting (@nestjs/throttler; in-memory — use one instance or Redis storage for multi-node)
# THROTTLE_TTL_MS=60000
# THROTTLE_GLOBAL_LIMIT=100
# THROTTLE_LOGIN_LIMIT=5
# THROTTLE_DISABLED=true
# TRUST_PROXY=true

# Cloudinary (uploads use access_mode=public)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=trackpro

# Gemini AI (POST /api/v1/ai/*)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# MongoDB
MONGODB_URI=mongodb://localhost:27017/trackpro

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# httpOnly JWT cookie (optional for web; mobile uses Bearer only)
# JWT_COOKIE_NAME=access_token
# JWT_COOKIE_SAMESITE=lax
# JWT_COOKIE_SECURE=false
# JWT_COOKIE_DOMAIN=
# Leave DOMAIN empty on localhost. SECURE=false for http://localhost

# Email — Gmail OAuth2 only (Gmail API via googleapis; no SMTP)
# Obtain a refresh token via Google OAuth Playground with Gmail send scope.
# Skip startup OAuth verify: EMAIL_VERIFY_ON_BOOT=false

GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxx
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=1//0g...
GMAIL_USER=youraccount@gmail.com
GMAIL_FROM=Trackpro <youraccount@gmail.com>

# Aliases (same as GMAIL_* above — supported by EmailService)
# CLIENT_ID=
# CLIENT_SECRET=
# REDIRECT_URI=
# REFRESH_TOKEN=
# GMAIL_NAME=
